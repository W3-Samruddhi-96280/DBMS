/*
5. Find names and numbers of all salesperson who have more than one
customer.
*/

mysql> SELECT s.sname, s.snum
    -> FROM salespeople s
    -> WHERE s.snum IN
    -> (
    ->     SELECT snum
    ->     FROM customers
    ->     GROUP BY snum
    ->     HAVING COUNT(*) > 1
    -> );
+--------+------+
| sname  | snum |
+--------+------+
| Peel   | 1001 |
| Serres | 1002 |
+--------+------+
2 rows in set (0.07 sec)


